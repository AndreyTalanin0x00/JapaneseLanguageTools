{
  "AllowedHosts": "*",
  "SpaStaticFiles": {
    "RootPath": "./ReactSpa"
  },
  "ConnectionStrings": {
    "MainConnectionString": "Data Source=~/.sqlite/JapaneseLanguageTools.db;"
  },
  "PluggableAssemblies": {
    "JapaneseLanguageTools.Data": "JapaneseLanguageTools.Data.Sqlite"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  }
}
