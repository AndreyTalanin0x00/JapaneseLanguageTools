{
  "SpaStaticFiles": {
    "RootPath": "./ReactSpa"
  },
  "SpaDevelopmentServer": {
    "UseExternalDevelopmentServer": false,
    "ExternalDevelopmentServerBaseUri": "http://localhost:5238/"
  },
  "ConnectionStrings": {
    "MainConnectionString": "Data Source=~/.sqlite/JapaneseLanguageTools.db;"
  },
  "PluggableAssemblies": {
    "JapaneseLanguageTools.Data": "JapaneseLanguageTools.Data.Sqlite"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  }
}
