{
  "name": "japanese-language-tools",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "vite",
    "preview": "vite preview",
    "test": "vitest run",
    "test-watch": "vitest watch",
    "build": "tsc",
    "publish": "tsc && vite build",
    "format": "npx prettier --write \"**/*.{md,html,js,jsx,ts,tsx,css,less,json,yml,yaml}\"",
    "format-check": "npx prettier --check \"**/*.{md,html,js,jsx,ts,tsx,css,less,json,yml,yaml}\"",
    "lint": "eslint . --ext js,jsx,ts,tsx --report-unused-disable-directives --max-warnings 0",
    "clean": "rimraf build",
    "clean-all": "rimraf build & rimraf node_modules"
  },
  "engines": {
    "node": ">=8.3.0"
  },
  "dependencies": {
    "@ant-design/colors": "^7.2.0",
    "@ant-design/icons": "^5.6.0",
    "antd": "^5.14.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router": "^7.6.0",
    "react-router-dom": "^7.6.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/node": "^24.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.36.0",
    "@typescript-eslint/parser": "^8.36.0",
    "@vitejs/plugin-react": "^4.2.0",
    "eslint": "^8.57.0",
    "eslint-import-resolver-typescript": "^4.4.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-react": "^7.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.6.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.8.0",
    "vite": "^6.2.0",
    "vitest": "^3.2.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-arm64-gnu": "^4.45.0",
    "@rollup/rollup-linux-arm64-musl": "^4.45.0",
    "@rollup/rollup-linux-riscv64-gnu": "^4.45.0",
    "@rollup/rollup-linux-x64-gnu": "^4.45.0",
    "@rollup/rollup-linux-x64-musl": "^4.45.0",
    "@rollup/rollup-win32-arm64-msvc": "^4.45.0",
    "@rollup/rollup-win32-ia32-msvc": "^4.45.0",
    "@rollup/rollup-win32-x64-msvc": "^4.45.0"
  }
}
